# iBirdOS Production Environment — workspace.ibirdos.com
# Every value marked REQUIRED must be set before deploy

# ── Database (Railway PostgreSQL URL) ──────────────────────────
DATABASE_URL=postgresql://postgres:PASSWORD@containers-us-west-XX.railway.app:PORT/railway
DB_PASSWORD=STRONG_RANDOM_PASSWORD_HERE

# ── Redis (Railway Redis URL) ──────────────────────────────────
REDIS_URL=redis://default:PASSWORD@containers-us-west-XX.railway.app:PORT

# ── Auth ──────────────────────────────────────────────────────
# REQUIRED: Run: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=PASTE_64_CHAR_HEX_STRING_HERE
JWT_EXPIRES_IN=7d

# ── URLs ──────────────────────────────────────────────────────
FRONTEND_URL=https://workspace.ibirdos.com
NEXT_PUBLIC_API_URL=https://api.ibirdos.com/api
NEXT_PUBLIC_APP_URL=https://workspace.ibirdos.com
PORT=3001

# ── OpenAI (REQUIRED for invoice parsing) ─────────────────────
# Get from: platform.openai.com → API Keys
OPENAI_API_KEY=sk-proj-XXXXXXXX

# ── Cloudflare R2 Storage (REQUIRED for invoice file uploads) ──
# Get from: dash.cloudflare.com → R2 → Manage API Tokens
S3_BUCKET=ibirdos-files
S3_REGION=auto
S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
S3_ACCESS_KEY=CLOUDFLARE_R2_ACCESS_KEY
S3_SECRET_KEY=CLOUDFLARE_R2_SECRET_KEY
S3_CDN_URL=https://pub-HASH.r2.dev

# ── Email via Resend.com (REQUIRED for invite emails) ─────────
# Get from: resend.com → API Keys (free 3000 emails/mo)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_XXXXXXXXXX
SMTP_FROM=noreply@ibirdos.com

# ── Stripe LIVE Keys (REQUIRED for payments) ──────────────────
# Get from: dashboard.stripe.com → Developers → API Keys
# Switch to LIVE mode before copying
STRIPE_SECRET_KEY=sk_live_XXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXX
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_XXXXXXXX

# ── Production settings ───────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
